<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.socialmediaapp.Controller.AuthController"
            styleClass="auth-root">
    <center>
        <HBox spacing="40" alignment="CENTER">
            <padding>
                <Insets top="40" right="60" bottom="40" left="60"/>
            </padding>

            <!-- Brand / intro side -->
            <VBox spacing="16" VBox.vgrow="ALWAYS">
                <Label text="Social Media App" styleClass="auth-title"/>
                <Label text="Connect, share, and explore a modern social experience."
                       wrapText="true"
                       maxWidth="260"
                       styleClass="auth-subtitle"/>
            </VBox>

            <!-- Auth forms side -->
            <TabPane tabClosingPolicy="UNAVAILABLE" prefWidth="380">
                <tabs>
                    <Tab text="Login">
                        <VBox spacing="12" styleClass="auth-card">
                            <padding>
                                <Insets top="18" right="20" bottom="18" left="20"/>
                            </padding>
                            <Label text="Welcome back" styleClass="section-label"/>
                            <TextField fx:id="loginEmailField" promptText="Email"/>
                            <PasswordField fx:id="loginPasswordField" promptText="Password"/>
                            <Button text="Sign in" onAction="#onLogin" styleClass="primary-button"/>
                        </VBox>
                    </Tab>

                    <Tab text="Register">
                        <VBox spacing="12" styleClass="auth-card">
                            <padding>
                                <Insets top="18" right="20" bottom="18" left="20"/>
                            </padding>
                            <Label text="Create an account" styleClass="section-label"/>
                            <TextField fx:id="registerNameField" promptText="Full name"/>
                            <TextField fx:id="registerEmailField" promptText="Email"/>
                            <PasswordField fx:id="registerPasswordField" promptText="Password"/>
                            <HBox spacing="8">
                                <Button text="Upload profile picture" onAction="#onChooseRegisterImage"/>
                                <Label fx:id="registerImageLabel" text="No image selected" />
                            </HBox>
                            <Button text="Sign up" onAction="#onRegister" styleClass="primary-button"/>
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER">
            <padding>
                <Insets top="8" right="12" bottom="12" left="12"/>
            </padding>
            <Label fx:id="statusLabel" text="" styleClass="auth-status"/>
        </HBox>
    </bottom>
</BorderPane>

